<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Keybusy_DiskScope.Views.ScanPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    xmlns:models="using:Keybusy_DiskScope.Models"
    xmlns:vm="using:Keybusy_DiskScope.ViewModels"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    x:DefaultBindMode="OneTime">

    <Grid Padding="24" RowDefinitions="Auto,Auto,Auto,*" RowSpacing="16">

        <!-- Header -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
            <StackPanel Grid.Row="0" Grid.Column="0" Spacing="4">
                <TextBlock Text="{x:Bind ViewModel.ScanTitle}" Style="{ThemeResource TitleTextBlockStyle}" />
                <TextBlock Text="{x:Bind ViewModel.ScanSummary}"
                           Visibility="{x:Bind ViewModel.HasSummary, Converter={StaticResource BoolToVisibilityConverter}}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource PillStyle}" VerticalAlignment="Center">
                <TextBlock Text="{x:Bind ViewModel.ResultsSummary}" />
            </Border>

            <TextBlock Grid.Row="1" Grid.ColumnSpan="2"
                       Text="{x:Bind ViewModel.RootDisplayLabel}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        </Grid>

        <!-- Scan controls -->
        <Grid Grid.Row="1" ColumnDefinitions="2*,Auto,Auto,Auto" ColumnSpacing="12" RowSpacing="8">
            <ComboBox Grid.Column="0"
                      ItemsSource="{x:Bind ViewModel.AvailableDrives}"
                      SelectedItem="{x:Bind ViewModel.SelectedDrive, Mode=TwoWay}"
                      PlaceholderText="Seleccione unidad"
                      AutomationProperties.Name="Seleccionar unidad" />

            <Button Grid.Column="1"
                    Command="{x:Bind ViewModel.StartScanCommand}"
                    AutomationProperties.Name="Iniciar escaneo">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE768;" />
                    <TextBlock Text="Escanear" />
                </StackPanel>
            </Button>

            <Button Grid.Column="2"
                    Command="{x:Bind ViewModel.CancelStartScanCommand}"
                    IsEnabled="{x:Bind ViewModel.IsScanning}"
                    AutomationProperties.Name="Cancelar escaneo">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE711;" />
                    <TextBlock Text="Cancelar" />
                </StackPanel>
            </Button>

            <TextBox Grid.Column="3"
                     Text="{x:Bind ViewModel.SnapshotName, Mode=TwoWay}"
                     PlaceholderText="Nombre del snapshot"
                     AutomationProperties.Name="Nombre del snapshot" />
        </Grid>

        <!-- Filters + actions -->
        <Grid Grid.Row="2" ColumnDefinitions="*,Auto" ColumnSpacing="12">
            <StackPanel Orientation="Horizontal" Spacing="16">
                <ComboBox ItemsSource="{x:Bind ViewModel.SortOptions}"
                          SelectedIndex="{x:Bind ViewModel.SelectedSortIndex, Mode=TwoWay}"
                          Width="200"
                          AutomationProperties.Name="Ordenar por" />

                <CheckBox Content="Solo carpetas"
                          IsChecked="{x:Bind ViewModel.FilterDirectoriesOnly, Mode=TwoWay}"
                          AutomationProperties.Name="Filtrar solo carpetas" />

                <CheckBox Content=">= 1 GB"
                          IsChecked="{x:Bind ViewModel.FilterLargeOnly, Mode=TwoWay}"
                          AutomationProperties.Name="Filtrar solo elementos grandes" />
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                <Button Click="ExpandAll_Click" AutomationProperties.Name="Expandir todo">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE8A7;" />
                        <TextBlock Text="Expandir" />
                    </StackPanel>
                </Button>
                <Button Click="CollapseAll_Click" AutomationProperties.Name="Contraer todo">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE8A8;" />
                        <TextBlock Text="Contraer" />
                    </StackPanel>
                </Button>
                <Button Command="{x:Bind ViewModel.SaveSnapshotCommand}"
                        AutomationProperties.Name="Guardar snapshot">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE74E;" />
                        <TextBlock Text="Guardar" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Results -->
        <Grid Grid.Row="3" RowDefinitions="Auto,Auto,*" RowSpacing="12">
            <InfoBar
                IsOpen="{x:Bind ViewModel.HasError, Mode=OneWay}"
                Severity="Error"
                Title="Error del escaneo"
                Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                IsClosable="True" />

            <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="10">
                <ProgressRing IsActive="{x:Bind ViewModel.IsScanning, Mode=OneWay}"
                              Width="18" Height="18"
                              AutomationProperties.Name="Escaneando" />
                <TextBlock Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <Grid Grid.Row="2" RowDefinitions="Auto,*" RowSpacing="8">
                <Grid ColumnDefinitions="2*,Auto,Auto,Auto,Auto" Padding="8,6" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <TextBlock Text="Nombre" FontWeight="SemiBold" />
                    <TextBlock Grid.Column="1" Text="Tamano" FontWeight="SemiBold" HorizontalAlignment="Right" />
                    <TextBlock Grid.Column="2" Text="%" FontWeight="SemiBold" HorizontalAlignment="Right" Margin="16,0,0,0" />
                    <TextBlock Grid.Column="3" Text="Archivos" FontWeight="SemiBold" HorizontalAlignment="Right" Margin="16,0,0,0" />
                    <TextBlock Grid.Column="4" Text="Modificado" FontWeight="SemiBold" HorizontalAlignment="Right" Margin="16,0,0,0" />
                </Grid>

                <controls:TreeView
                    Grid.Row="1"
                    x:Name="ScanTree"
                    ItemsSource="{x:Bind ViewModel.DisplayNodes}"
                    AutomationProperties.Name="Resultados del escaneo">
                    <controls:TreeView.ItemTemplate>
                        <DataTemplate x:DataType="models:DiskNode">
                            <controls:TreeViewItem ItemsSource="{x:Bind Children}"
                                                   AutomationProperties.Name="{x:Bind Name}">
                                <controls:TreeViewItem.Content>
                                    <Grid ColumnDefinitions="2*,Auto,Auto,Auto,Auto" Padding="8,4">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon Glyph="{x:Bind IconGlyph}" />
                                            <TextBlock Text="{x:Bind Name}" />
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" Text="{x:Bind DisplaySize}" HorizontalAlignment="Right" />
                                        <TextBlock Grid.Column="2" Text="{x:Bind DisplayPercent}" HorizontalAlignment="Right" Margin="16,0,0,0" />
                                        <TextBlock Grid.Column="3" Text="{x:Bind DisplayFileCount}" HorizontalAlignment="Right" Margin="16,0,0,0" />
                                        <TextBlock Grid.Column="4" Text="{x:Bind DisplayLastModified}" HorizontalAlignment="Right" Margin="16,0,0,0" />
                                    </Grid>
                                </controls:TreeViewItem.Content>
                            </controls:TreeViewItem>
                        </DataTemplate>
                    </controls:TreeView.ItemTemplate>
                </controls:TreeView>
            </Grid>
        </Grid>
    </Grid>
</Page>
