<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Keybusy_DiskScope.Views.ScanPage"
    x:Name="Root"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    xmlns:models="using:Keybusy_DiskScope.Models"
    xmlns:vm="using:Keybusy_DiskScope.ViewModels"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    x:DefaultBindMode="OneTime">
    <Page.KeyboardAccelerators>
        <KeyboardAccelerator Key="Delete"
                             Invoked="DeleteAccelerator_Invoked" />
        <KeyboardAccelerator Key="Delete"
                             Modifiers="Shift"
                             Invoked="DeletePermanentAccelerator_Invoked" />
    </Page.KeyboardAccelerators>

    <Grid Padding="24" RowDefinitions="Auto,*" RowSpacing="12">

        <!-- Compact top bar -->
        <Grid Grid.Row="0"
              ColumnDefinitions="Auto,Auto,Auto,Auto,Auto,Auto"
              ColumnSpacing="10"
              VerticalAlignment="Center">
            <TextBlock Grid.Column="0"
                       Text="{x:Bind ViewModel.ScanTitle}"
                       Style="{ThemeResource TitleTextBlockStyle}" />

            <ComboBox Grid.Column="1"
                      Width="160"
                      ItemsSource="{x:Bind ViewModel.SortOptions}"
                      SelectedIndex="{x:Bind ViewModel.SelectedSortIndex, Mode=TwoWay}"
                      AutomationProperties.Name="Ordenar por" />

            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="10">
                <CheckBox Content="Solo carpetas"
                          IsChecked="{x:Bind ViewModel.FilterDirectoriesOnly, Mode=TwoWay}"
                          AutomationProperties.Name="Filtrar solo carpetas" />
                <CheckBox Content=">= 1 GB"
                          IsChecked="{x:Bind ViewModel.FilterLargeOnly, Mode=TwoWay}"
                          AutomationProperties.Name="Filtrar solo elementos grandes" />
            </StackPanel>

            <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="8">
                <Button Command="{x:Bind ViewModel.StartScanCommand}"
                        AutomationProperties.Name="Iniciar escaneo">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE768;" />
                        <TextBlock Text="Escanear" />
                    </StackPanel>
                </Button>
                <Button Command="{x:Bind ViewModel.CancelStartScanCommand}"
                        IsEnabled="{x:Bind ViewModel.IsScanning}"
                        AutomationProperties.Name="Cancelar escaneo">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE711;" />
                        <TextBlock Text="Cancelar" />
                    </StackPanel>
                </Button>
            </StackPanel>

            <TextBox Grid.Column="4"
                     Width="200"
                     Text="{x:Bind ViewModel.SnapshotName, Mode=TwoWay}"
                     PlaceholderText="Nombre del snapshot"
                     AutomationProperties.Name="Nombre del snapshot" />

            <Button Grid.Column="5"
                    x:Name="SaveSnapshotButton"
                    Command="{x:Bind ViewModel.SaveSnapshotCommand}"
                    IsEnabled="{x:Bind ViewModel.IsScanning, Converter={StaticResource BoolNegationConverter}}"
                    AutomationProperties.Name="Guardar snapshot">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <ProgressRing Width="14" Height="14"
                                  IsActive="{x:Bind ViewModel.IsSavingSnapshot, Mode=OneWay}"
                                  Visibility="{x:Bind ViewModel.IsSavingSnapshot, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}"
                                  AutomationProperties.Name="Guardando snapshot" />
                    <FontIcon Glyph="&#xE74E;" />
                    <TextBlock Text="Guardar" />
                </StackPanel>
            </Button>

            <TeachingTip Target="{x:Bind SaveSnapshotButton}"
                         Title="Snapshot guardado"
                         Subtitle="{x:Bind ViewModel.SavedSnapshotMessage, Mode=OneWay}"
                         IsOpen="{x:Bind ViewModel.IsSaveTipOpen, Mode=TwoWay}"
                         ActionButtonContent="Aceptar"
                         ActionButtonClick="SaveTip_ActionButtonClick"
                         CloseButtonClick="SaveTip_CloseButtonClick" />
        </Grid>

        <!-- Results -->
        <Grid Grid.Row="1" RowDefinitions="Auto,*" RowSpacing="8">
            <InfoBar
                IsOpen="{x:Bind ViewModel.HasError, Mode=OneWay}"
                Severity="Error"
                Title="Error del escaneo"
                Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                IsClosable="True" />

            <Grid Grid.Row="1" RowDefinitions="Auto,*" RowSpacing="8">
                <Border Grid.RowSpan="2"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="12"
                        Visibility="{x:Bind ViewModel.IsScanning, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
                        <ProgressRing IsActive="{x:Bind ViewModel.IsScanning, Mode=OneWay}"
                                      Width="56" Height="56"
                                      AutomationProperties.Name="Escaneando" />
                        <TextBlock Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                </Border>
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8"
                        Padding="8,6"
                        Visibility="{x:Bind ViewModel.IsNotScanning, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}">
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="{x:Bind ViewModel.ShowSizeColumn, Converter={StaticResource BoolToGridLengthConverter}, ConverterParameter=140}" />
                            <ColumnDefinition Width="{x:Bind ViewModel.ShowPercentColumn, Converter={StaticResource BoolToGridLengthConverter}, ConverterParameter=60}" />
                            <ColumnDefinition Width="{x:Bind ViewModel.ShowFilesColumn, Converter={StaticResource BoolToGridLengthConverter}, ConverterParameter=90}" />
                            <ColumnDefinition Width="{x:Bind ViewModel.ShowModifiedColumn, Converter={StaticResource BoolToGridLengthConverter}, ConverterParameter=170}" />
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Command="{x:Bind ViewModel.SortByCommand}"
                                CommandParameter="{x:Bind ViewModel.NameSortIndex, Mode=OneTime}"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="0"
                                HorizontalAlignment="Left"
                                AutomationProperties.Name="Ordenar por nombre">
                            <TextBlock Text="Nombre" FontWeight="SemiBold" />
                        </Button>

                        <Button Grid.Column="1"
                                Command="{x:Bind ViewModel.SortByCommand}"
                                CommandParameter="{x:Bind ViewModel.SizeSortIndex, Mode=OneTime}"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="0"
                                HorizontalAlignment="Right"
                                AutomationProperties.Name="Ordenar por tamano"
                                Visibility="{x:Bind ViewModel.ShowSizeColumn, Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Right">
                                <TextBlock Text="Tamano" FontWeight="SemiBold" />
                                <FontIcon Glyph="{x:Bind ViewModel.SizeSortGlyph}"
                                          Visibility="{x:Bind ViewModel.IsSizeSort, Converter={StaticResource BoolToVisibilityConverter}}" />
                            </StackPanel>
                        </Button>

                        <Button Grid.Column="2"
                                Command="{x:Bind ViewModel.SortByCommand}"
                                CommandParameter="{x:Bind ViewModel.PercentSortIndex, Mode=OneTime}"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="0"
                                HorizontalAlignment="Right"
                                AutomationProperties.Name="Ordenar por porcentaje"
                                Visibility="{x:Bind ViewModel.ShowPercentColumn, Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Right">
                                <TextBlock Text="%" FontWeight="SemiBold" />
                                <FontIcon Glyph="{x:Bind ViewModel.PercentSortGlyph}"
                                          Visibility="{x:Bind ViewModel.IsPercentSort, Converter={StaticResource BoolToVisibilityConverter}}" />
                            </StackPanel>
                        </Button>

                        <Button Grid.Column="3"
                                Command="{x:Bind ViewModel.SortByCommand}"
                                CommandParameter="{x:Bind ViewModel.FilesSortIndex, Mode=OneTime}"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="0"
                                HorizontalAlignment="Right"
                                AutomationProperties.Name="Ordenar por archivos"
                                Visibility="{x:Bind ViewModel.ShowFilesColumn, Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Right">
                                <TextBlock Text="Archivos" FontWeight="SemiBold" />
                                <FontIcon Glyph="{x:Bind ViewModel.FilesSortGlyph}"
                                          Visibility="{x:Bind ViewModel.IsFilesSort, Converter={StaticResource BoolToVisibilityConverter}}" />
                            </StackPanel>
                        </Button>

                        <Button Grid.Column="4"
                                Command="{x:Bind ViewModel.SortByCommand}"
                                CommandParameter="{x:Bind ViewModel.ModifiedSortIndex, Mode=OneTime}"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="0"
                                HorizontalAlignment="Right"
                                AutomationProperties.Name="Ordenar por modificado"
                                Visibility="{x:Bind ViewModel.ShowModifiedColumn, Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Right">
                                <TextBlock Text="Modificado" FontWeight="SemiBold" />
                                <FontIcon Glyph="{x:Bind ViewModel.ModifiedSortGlyph}"
                                          Visibility="{x:Bind ViewModel.IsModifiedSort, Converter={StaticResource BoolToVisibilityConverter}}" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="1"
                              x:Name="ResultsScroll"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              IsTabStop="True"
                              Visibility="{x:Bind ViewModel.IsNotScanning, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}">
                    <controls:ItemsRepeater
                        ItemsSource="{x:Bind ViewModel.DisplayNodes}">
                        <controls:ItemsRepeater.Layout>
                            <controls:StackLayout Orientation="Vertical" />
                        </controls:ItemsRepeater.Layout>
                        <controls:ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="models:DiskNode">
                                <Border Background="{x:Bind IsSelected, Converter={StaticResource BoolToSelectionBrushConverter}, Mode=OneTime}"
                                        CornerRadius="6"
                                        PointerPressed="Row_PointerPressed"
                                        RightTapped="Row_RightTapped">
                                    <Border.ContextFlyout>
                                        <MenuFlyout>
                                            <MenuFlyoutItem Text="Eliminar"
                                                            Tag="{x:Bind}"
                                                            Click="DeleteMenuItem_Click"
                                                            AutomationProperties.Name="Eliminar elemento" />
                                        </MenuFlyout>
                                    </Border.ContextFlyout>
                                    <Grid Padding="8,4"
                                          ColumnSpacing="8">
                                    <Grid.Transitions>
                                        <TransitionCollection>
                                            <EntranceThemeTransition FromVerticalOffset="6" />
                                        </TransitionCollection>
                                    </Grid.Transitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="{Binding ElementName=Root, Path=ViewModel.ShowSizeColumn, Converter={StaticResource BoolToGridLengthConverter}, ConverterParameter=140}" />
                                        <ColumnDefinition Width="{Binding ElementName=Root, Path=ViewModel.ShowPercentColumn, Converter={StaticResource BoolToGridLengthConverter}, ConverterParameter=60}" />
                                        <ColumnDefinition Width="{Binding ElementName=Root, Path=ViewModel.ShowFilesColumn, Converter={StaticResource BoolToGridLengthConverter}, ConverterParameter=90}" />
                                        <ColumnDefinition Width="{Binding ElementName=Root, Path=ViewModel.ShowModifiedColumn, Converter={StaticResource BoolToGridLengthConverter}, ConverterParameter=170}" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Orientation="Horizontal"
                                                Spacing="8"
                                                Margin="{x:Bind Depth, Converter={StaticResource DepthToThicknessConverter}, ConverterParameter=20, Mode=OneTime}">
                                        <Button Command="{Binding ElementName=Root, Path=ViewModel.ToggleExpandAndSelectCommand}"
                                                CommandParameter="{x:Bind}"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Padding="0"
                                                Width="20"
                                                IsEnabled="{x:Bind HasChildren}"
                                                AutomationProperties.Name="Expandir o contraer carpeta">
                                            <FontIcon Glyph="{x:Bind ExpandGlyph}"
                                                      FontSize="12"
                                                      Opacity="0.65"
                                                      Visibility="{x:Bind HasChildren, Converter={StaticResource BoolToVisibilityConverter}}" />
                                        </Button>
                                        <Button Command="{Binding ElementName=Root, Path=ViewModel.ToggleExpandAndSelectCommand}"
                                                CommandParameter="{x:Bind}"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Padding="0"
                                                AutomationProperties.Name="Abrir elemento">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <FontIcon Glyph="&#xE8B7;"
                                                          Foreground="{ThemeResource FolderIconBrush}"
                                                          Visibility="{x:Bind IsDirectory, Converter={StaticResource BoolToVisibilityConverter}}" />
                                                <FontIcon Glyph="&#xE8A5;"
                                                          Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                                          Visibility="{x:Bind IsFile, Converter={StaticResource BoolToVisibilityConverter}}" />
                                                <TextBlock Text="{x:Bind Name}" />
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1"
                                               Text="{x:Bind DisplaySize}"
                                               HorizontalAlignment="Right"
                                               Visibility="{Binding ElementName=Root, Path=ViewModel.ShowSizeColumn, Converter={StaticResource BoolToVisibilityConverter}}" />
                                    <TextBlock Grid.Column="2"
                                               Text="{x:Bind DisplayPercent}"
                                               HorizontalAlignment="Right"
                                               Visibility="{Binding ElementName=Root, Path=ViewModel.ShowPercentColumn, Converter={StaticResource BoolToVisibilityConverter}}" />
                                    <TextBlock Grid.Column="3"
                                               Text="{x:Bind DisplayFileCount}"
                                               HorizontalAlignment="Right"
                                               Visibility="{Binding ElementName=Root, Path=ViewModel.ShowFilesColumn, Converter={StaticResource BoolToVisibilityConverter}}" />
                                    <TextBlock Grid.Column="4"
                                               Text="{x:Bind DisplayLastModified}"
                                               HorizontalAlignment="Right"
                                               Visibility="{Binding ElementName=Root, Path=ViewModel.ShowModifiedColumn, Converter={StaticResource BoolToVisibilityConverter}}" />
                                </Grid>
                            </Border>
                            </DataTemplate>
                        </controls:ItemsRepeater.ItemTemplate>
                    </controls:ItemsRepeater>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</Page>
