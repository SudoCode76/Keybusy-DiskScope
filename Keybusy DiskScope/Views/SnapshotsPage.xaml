<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Keybusy_DiskScope.Views.SnapshotsPage"
    x:Name="Root"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Keybusy_DiskScope.ViewModels"
    xmlns:models="using:Keybusy_DiskScope.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    x:DefaultBindMode="OneTime">

    <Grid RowDefinitions="Auto,Auto,*" RowSpacing="12" Padding="24">

        <TextBlock Grid.Row="0"
                   Text="Snapshots guardados"
                   Style="{ThemeResource TitleTextBlockStyle}" />

        <InfoBar Grid.Row="1"
                 IsOpen="{x:Bind ViewModel.HasError, Mode=OneWay}"
                 Severity="Error"
                 Title="Error"
                 Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                 IsClosable="True" />

        <Border Grid.Row="2"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                CornerRadius="12"
                Padding="12">
            <Grid RowDefinitions="Auto,*" RowSpacing="8">
                <Border Grid.RowSpan="2"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="12"
                        Visibility="{x:Bind ViewModel.IsLoading, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
                        <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                                      Width="56" Height="56"
                                      AutomationProperties.Name="Cargando snapshots" />
                        <TextBlock Text="Cargando snapshots..."
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                </Border>

                <TextBlock Grid.Row="0"
                           Text="No hay snapshots guardados"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Visibility="{x:Bind ViewModel.HasNoSnapshots, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}" />

                <ListView Grid.Row="1"
                          ItemsSource="{x:Bind ViewModel.Snapshots}"
                          SelectionMode="Single"
                          SelectedItem="{x:Bind ViewModel.SelectedSnapshot, Mode=TwoWay}"
                          Visibility="{x:Bind ViewModel.HasSnapshots, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}"
                          AutomationProperties.Name="Lista de snapshots">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:SnapshotRecord">
                            <Border Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                    CornerRadius="8"
                                    Padding="12">
                                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="12" RowSpacing="2">
                                    <TextBlock Text="{x:Bind Name}" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                    <TextBlock Grid.Row="1"
                                               Text="{x:Bind DrivePath}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <TextBlock Grid.Column="1"
                                               Text="{x:Bind CreatedAt, Mode=OneWay, Converter={StaticResource DateTimeToStringConverter}, ConverterParameter=g}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               HorizontalAlignment="Right" />
                                    <Button Grid.Column="1" Grid.Row="1"
                                            HorizontalAlignment="Right"
                                            Click="DeleteSnapshot_Click"
                                            AutomationProperties.Name="Eliminar snapshot">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <FontIcon Glyph="&#xE74D;" />
                                            <TextBlock Text="Eliminar" />
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>

    </Grid>
</Page>
