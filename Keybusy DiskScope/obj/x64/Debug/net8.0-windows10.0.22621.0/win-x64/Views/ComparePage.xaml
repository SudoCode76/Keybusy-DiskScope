<?xml version="1.0" encoding="utf-8"?>
<Page x:ConnectionId='1'
    x:Class="Keybusy_DiskScope.Views.ComparePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Keybusy_DiskScope.ViewModels"
    xmlns:models="using:Keybusy_DiskScope.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid RowDefinitions="Auto,Auto,Auto,*">

        <TextBlock Grid.Row="0"
                   Text="Comparar snapshots"
                   Style="{ThemeResource TitleTextBlockStyle}"
                   Margin="0,0,0,16" />

        <!-- Snapshot selectors -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="16" Margin="0,0,0,12">

            <StackPanel Spacing="4">
                <TextBlock Text="Antes" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                <ComboBox x:ConnectionId='7'                                                    
                                                                                       
                          MinWidth="220"
                          AutomationProperties.Name="Snapshot anterior">
                    <ComboBox.ItemTemplate>
                        <DataTemplate                                   >
                            <TextBlock x:ConnectionId='9'                      />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </StackPanel>

            <StackPanel Spacing="4">
                <TextBlock Text="Después" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                <ComboBox x:ConnectionId='4'                                                    
                                                                                      
                          MinWidth="220"
                          AutomationProperties.Name="Snapshot posterior">
                    <ComboBox.ItemTemplate>
                        <DataTemplate                                   >
                            <TextBlock x:ConnectionId='6'                      />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </StackPanel>

            <Button x:ConnectionId='3'                                               
                    VerticalAlignment="Bottom"
                    AutomationProperties.Name="Comparar snapshots">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE8A9;" />
                    <TextBlock Text="Comparar" />
                </StackPanel>
            </Button>
        </StackPanel>

        <InfoBar x:ConnectionId='2' Grid.Row="2"
                                                                   
                 Severity="Error"
                 Title="Error en la comparación"
                                                                        
                 IsClosable="True"
                 Margin="0,0,0,12" />

        <!-- Diff tree placeholder (UI will be designed by owner) -->
        <Border Grid.Row="3"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                CornerRadius="8"
                Padding="16">
            <TextBlock Text="Selecciona dos snapshots y pulsa Comparar"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />
        </Border>

    </Grid>
</Page>

