<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Keybusy_DiskScope.Views.AboutPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24" RowDefinitions="Auto,Auto,Auto,*" RowSpacing="12">
        <StackPanel Grid.Row="0" Spacing="4">
            <TextBlock Text="Acerca de" Style="{ThemeResource TitleTextBlockStyle}" />
            <TextBlock Text="Informacion general de Keybusy DiskScope y enlaces de contacto."
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        </StackPanel>

        <Border Grid.Row="1"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                CornerRadius="12"
                Padding="16">
            <StackPanel Spacing="8">
                <TextBlock Text="Keybusy DiskScope" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                <TextBlock Text="Aplicacion de analisis de uso de disco para Windows con snapshots historicos y comparacion entre analisis."
                           TextWrapping="Wrap"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <TextBlock Text="Funciones principales:" FontWeight="SemiBold" />
                <TextBlock Text="- Analisis de unidad en vivo&#10;- Guardado de snapshots&#10;- Comparacion entre snapshots y estado actual"
                           TextWrapping="Wrap"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>
        </Border>

        <Border Grid.Row="2"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                CornerRadius="12"
                Padding="16">
            <StackPanel Spacing="12">
                <TextBlock Text="Contacto y proyectos" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                <TextBlock Text="Si quieres un programa personalizado, colaborar en un proyecto o contactarme, puedes usar estos enlaces:"
                           TextWrapping="Wrap"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                <StackPanel Orientation="Horizontal" Spacing="10">
                    <Button Click="OpenGitHub_Click" AutomationProperties.Name="Abrir perfil de GitHub">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE943;" />
                            <TextBlock Text="GitHub" />
                        </StackPanel>
                    </Button>

                    <Button Click="OpenLinkedIn_Click" AutomationProperties.Name="Abrir perfil de LinkedIn">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE716;" />
                            <TextBlock Text="LinkedIn" />
                        </StackPanel>
                    </Button>

                    <Button Click="OpenWhatsApp_Click" AutomationProperties.Name="Abrir enlace de WhatsApp">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE8BD;" />
                            <TextBlock Text="WhatsApp" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </StackPanel>
        </Border>

        <TextBlock Grid.Row="3"
                   Text="Gracias por usar Keybusy DiskScope."
                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                   VerticalAlignment="Bottom" />
    </Grid>
</Page>
