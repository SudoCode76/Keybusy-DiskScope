<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="Keybusy_DiskScope.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Keybusy_DiskScope"
    xmlns:converters="using:Keybusy_DiskScope.Converters">
    <Application.Resources>
        <ResourceDictionary>
        <ResourceDictionary.MergedDictionaries>
            <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            <ResourceDictionary Source="/Resources/Styles.xaml" />
        </ResourceDictionary.MergedDictionaries>

            <converters:BoolNegationConverter x:Key="BoolNegationConverter" />
            <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
            <converters:BoolToGridLengthConverter x:Key="BoolToGridLengthConverter" />
            <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
            <converters:DepthToThicknessConverter x:Key="DepthToThicknessConverter" />
            <converters:BoolToSelectionBrushConverter x:Key="BoolToSelectionBrushConverter" />
            <converters:DiffStatusToBrushConverter x:Key="DiffStatusToBrushConverter" />
            <converters:DateTimeToStringConverter x:Key="DateTimeToStringConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
