## Ignore build outputs, user files and editor folders

# Visual Studio / MSBuild
.vs/
bin/
obj/
**/bin/
**/obj/
*.user
*.suo
*.userosscache
*.sln.docstates

# Rider / JetBrains
.idea/
*.sln.iml

# VS Code
.vscode/

# NuGet
packages/
*.nupkg
project.assets.json
project.nuget.cache
*.nuget.props
*.nuget.targets

# Publish / packaging
publish/
AppPackages/
*.appx
*.msix
*.msixbundle
*.appxbundle
*.appxupload

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Logs, temp
*.log
*.tmp
*.temp
~$*

# Test results / coverage
TestResults/
coverage/
*.coverage
*.coveragexml

# Generated by XAML compiler and intermediate files (explicit project paths)
/Keybusy DiskScope/obj/
/Keybusy DiskScope/bin/
/Keybusy DiskScope/*.AssemblyInfoInputs.cache
/Keybusy DiskScope/*xaml_output*.json
/Keybusy DiskScope/*xamlcompiler_out*.txt
/Keybusy DiskScope/build_*.txt
/Keybusy DiskScope/Keybusy DiskScope.csproj.nuget.dgspec.json
/Keybusy DiskScope/Keybusy DiskScope.csproj.user

# Agent/skills lock & generated metadata
/Keybusy DiskScope/skills-lock.json

# OS generated files
.DS_Store

# Sensitive or local settings
secrets.json

# Keep this file near the top of the repo so accidental local files are ignored
