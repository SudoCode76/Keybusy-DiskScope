<?xml version="1.0" encoding="utf-8"?>
<Page x:ConnectionId='1'
    x:Class="Keybusy_DiskScope.Views.ScanPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Keybusy_DiskScope.ViewModels"
    xmlns:models="using:Keybusy_DiskScope.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid RowDefinitions="Auto,Auto,*,Auto">

        <!-- Header -->
        <TextBlock Grid.Row="0"
                   Text="Escanear partición"
                   Style="{ThemeResource TitleTextBlockStyle}"
                   Margin="0,0,0,16" />

        <!-- Drive selector + scan button -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" Margin="0,0,0,12">
            <ComboBox x:ConnectionId='7' x:Name="DriveCombo"
                                                                      
                                                                                  
                      MinWidth="160"
                      AutomationProperties.Name="Seleccionar unidad" />

            <Button x:ConnectionId='8'                                              
                                                                                                                             
                    AutomationProperties.Name="Iniciar escaneo">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE896;" />
                    <TextBlock Text="Escanear" />
                </StackPanel>
            </Button>

            <Button x:ConnectionId='9'                                                    
                                                                                                                                  
                    AutomationProperties.Name="Cancelar escaneo">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE711;" />
                    <TextBlock Text="Cancelar" />
                </StackPanel>
            </Button>

            <ProgressRing x:ConnectionId='10'                                                       
                          Width="24" Height="24"
                          AutomationProperties.Name="Escaneando" />
        </StackPanel>

        <!-- Status / Error -->
        <InfoBar x:ConnectionId='2' Grid.Row="1"
                                                                   
                 Severity="Error"
                 Title="Error en el escaneo"
                                                                        
                 IsClosable="True"
                 Margin="0,48,0,0" />

        <!-- Tree placeholder (UI will be designed by owner) -->
        <Border Grid.Row="2"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                CornerRadius="8"
                Padding="16">
            <TextBlock x:ConnectionId='6'                                                   
                      Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                      TextWrapping="Wrap" />
        </Border>

        <!-- Save snapshot bar -->
        <StackPanel x:ConnectionId='3' Grid.Row="3"
                    Orientation="Horizontal"
                    Spacing="8"
                    Margin="0,12,0,0"
                                                                                                                                >
            <TextBox x:ConnectionId='4' PlaceholderText="Nombre del snapshot"
                                                                        
                     MinWidth="240"
                     AutomationProperties.Name="Nombre del snapshot" />
            <Button x:ConnectionId='5'                                                 
                    AutomationProperties.Name="Guardar snapshot">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE74E;" />
                    <TextBlock Text="Guardar snapshot" />
                </StackPanel>
            </Button>
        </StackPanel>

    </Grid>
</Page>

