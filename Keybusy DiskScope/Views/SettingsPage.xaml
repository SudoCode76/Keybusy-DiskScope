<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Keybusy_DiskScope.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Keybusy_DiskScope.ViewModels"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    x:DefaultBindMode="OneTime">

    <Grid Padding="24" RowDefinitions="Auto,Auto,*" RowSpacing="16">
        <TextBlock Text="Configuracion"
                   Style="{ThemeResource TitleTextBlockStyle}" />

        <Border Grid.Row="1"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                CornerRadius="8"
                Padding="16">
            <StackPanel Spacing="10">
                <TextBlock Text="General" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                <TextBlock Text="Preferencias basicas de la aplicacion."
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>
        </Border>

        <Border Grid.Row="2"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                CornerRadius="8"
                Padding="16">
            <StackPanel Spacing="12">
                <TextBlock Text="Personalizacion" Style="{ThemeResource BodyStrongTextBlockStyle}" />

                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" RowSpacing="6">
                    <TextBlock Text="Color de carpetas en el analisis"
                               FontWeight="SemiBold" />
                    <ToggleSwitch Grid.Column="1"
                                  IsOn="{x:Bind ViewModel.UseColoredFolderIcons, Mode=TwoWay}"
                                  AutomationProperties.Name="Activar color en iconos de carpetas" />
                    <TextBlock Grid.Row="1"
                               Grid.ColumnSpan="2"
                               Text="Activa un color distintivo para las carpetas en la vista de analisis."
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </Grid>

                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" RowSpacing="6">
                    <TextBlock Text="Tema de la aplicacion"
                               FontWeight="SemiBold" />
                    <ComboBox Grid.Column="1"
                              Width="180"
                              ItemsSource="{x:Bind ViewModel.ThemeOptionLabels}"
                              SelectedIndex="{x:Bind ViewModel.SelectedThemeIndex, Mode=TwoWay}"
                              AutomationProperties.Name="Seleccionar tema de la aplicacion" />
                    <TextBlock Grid.Row="1"
                               Grid.ColumnSpan="2"
                               Text="Elige entre claro, oscuro o seguir el tema del sistema."
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </Grid>

                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" RowSpacing="6">
                    <TextBlock Text="Orden por defecto"
                               FontWeight="SemiBold" />
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                        <ComboBox Width="180"
                                  ItemsSource="{x:Bind ViewModel.DefaultSortOptionLabels}"
                                  SelectedIndex="{x:Bind ViewModel.DefaultSortIndex, Mode=TwoWay}"
                                  AutomationProperties.Name="Seleccionar orden por defecto" />
                        <ComboBox Width="140"
                                  ItemsSource="{x:Bind ViewModel.SortDirectionLabels}"
                                  SelectedIndex="{x:Bind ViewModel.DefaultSortDirectionIndex, Mode=TwoWay}"
                                  AutomationProperties.Name="Seleccionar direccion de orden" />
                    </StackPanel>
                    <TextBlock Grid.Row="1"
                               Grid.ColumnSpan="2"
                               Text="Define la columna y el sentido de orden al iniciar un analisis."
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</Page>
