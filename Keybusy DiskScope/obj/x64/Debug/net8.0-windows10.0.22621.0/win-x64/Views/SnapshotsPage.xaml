<?xml version="1.0" encoding="utf-8"?>
<Page x:ConnectionId='1'
    x:Class="Keybusy_DiskScope.Views.SnapshotsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Keybusy_DiskScope.ViewModels"
    xmlns:models="using:Keybusy_DiskScope.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid RowDefinitions="Auto,Auto,*">

        <TextBlock Grid.Row="0"
                   Text="Snapshots guardados"
                   Style="{ThemeResource TitleTextBlockStyle}"
                   Margin="0,0,0,16" />

        <InfoBar x:ConnectionId='2' Grid.Row="1"
                                                                   
                 Severity="Error"
                 Title="Error"
                                                                        
                 IsClosable="True"
                 Margin="0,0,0,12" />

        <!-- Snapshots list placeholder (UI will be designed by owner) -->
        <Border Grid.Row="2"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                CornerRadius="8"
                Padding="16">
            <ProgressRing x:ConnectionId='3'                                                      
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          AutomationProperties.Name="Cargando snapshots" />
        </Border>

    </Grid>
</Page>

