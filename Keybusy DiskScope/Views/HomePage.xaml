<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Keybusy_DiskScope.Views.HomePage"
    x:Name="Root"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Keybusy_DiskScope.Views"
    xmlns:vm="using:Keybusy_DiskScope.ViewModels"
    xmlns:models="using:Keybusy_DiskScope.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    mc:Ignorable="d"
    x:DefaultBindMode="OneTime">

    <Page.Resources>
        <!-- ViewModel resolved in code-behind via DI or set as DataContext at runtime; keep DataTemplate x:DataType for type-safety -->
        <Style TargetType="TextBlock" x:Key="HeaderTitle">
            <Setter Property="FontSize" Value="20" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </Page.Resources>

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="12">
            <TextBlock Grid.Row="0"
                       Grid.Column="0"
                       Text="Mis Unidades"
                       Style="{StaticResource HeaderTitle}" />
            <TextBlock Grid.Row="1"
                       Grid.Column="0"
                       Text="Seleccione una unidad para comenzar el análisis detallado"
                       Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" />

            <Button Grid.RowSpan="2"
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    Click="RelaunchAsAdmin_Click"
                    AutomationProperties.Name="Reiniciar como administrador"
                    ToolTipService.ToolTip="Reinicia la aplicacion con permisos de administrador">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE72E;" />
                    <TextBlock Text="Reiniciar como admin" />
                </StackPanel>
            </Button>
        </Grid>

        <ScrollViewer Grid.Row="1" Margin="0,18,0,0" VerticalScrollBarVisibility="Auto">
            <controls:ItemsRepeater ItemsSource="{x:Bind ViewModel.Drives, Mode=OneTime}">
                <controls:ItemsRepeater.Layout>
                    <controls:StackLayout Orientation="Vertical" />
                </controls:ItemsRepeater.Layout>
                <controls:ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="vm:DriveCardViewModel" x:DefaultBindMode="OneTime">
                        <Border Style="{StaticResource CardBorderStyle}" MinHeight="140">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <!-- Left icon block (fixed width, center content) -->
                                <Border Grid.Column="0"
                                        Width="140"
                                        CornerRadius="8"
                                        Background="{ThemeResource LayerFillColorDefaultBrush}"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center">
                                    <Viewbox Margin="12" Stretch="Uniform">
                                        <FontIcon Glyph="&#xE7C8;" FontSize="48" />
                                    </Viewbox>
                                </Border>

                                <!-- Right content -->
                                <Grid Grid.Column="1">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <!-- Title row: title + pill on the left, actions on the right -->
                                    <Grid Grid.Row="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Grid.Column="0">
                                            <TextBlock Text="{x:Bind Drive.DisplayName, Mode=OneTime}" FontSize="18" FontWeight="SemiBold" />
                                            <Border Style="{StaticResource PillStyle}" Margin="12,0,0,0" VerticalAlignment="Center">
                                                <TextBlock Text="{x:Bind Drive.TypeLabel, Mode=OneTime}" FontSize="12" />
                                            </Border>
                                        </StackPanel>

                                         <Button Grid.Column="1" Margin="12,0,0,0" AutomationProperties.Name="Más opciones">
                                            <FontIcon Glyph="&#xE712;" />
                                            <Button.Flyout>
                                                <MenuFlyout>
                                                    <MenuFlyoutItem Text="Detalles"/>
                                                    <MenuFlyoutItem Text="Abrir en Explorador"/>
                                                </MenuFlyout>
                                            </Button.Flyout>
                                        </Button>
                                    </Grid>

                                    <TextBlock Grid.Row="1" Text="{x:Bind Drive.SubTitle, Mode=OneTime}" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" Margin="0,6,0,8" />

                                    <Grid Grid.Row="2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="160" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                                            <TextBlock Text="{x:Bind Drive.UsedDisplay, Mode=OneTime}" FontSize="28" FontWeight="Bold" />
                                            <TextBlock Text="USADOS" FontSize="11" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" />
                                            <ProgressBar Value="{x:Bind Drive.UsedPercentage, Mode=OneTime}" Maximum="100" Height="8" Margin="0,12,0,6" />
                                            <TextBlock Text="{x:Bind Drive.FreeDisplay, Mode=OneTime}" FontSize="12" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" />
                                        </StackPanel>

                                        <TextBlock Grid.Column="1" Text="{x:Bind Drive.TotalDisplay, Mode=OneTime}" HorizontalAlignment="Right" FontSize="20" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" VerticalAlignment="Center" />
                                    </Grid>

                                    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="12" Margin="0,12,0,0">
                                        <Button Content="Analizar Unidad"
                                                Command="{x:Bind AnalyzeCommand}"
                                                CommandParameter="{x:Bind Drive}"
                                                AutomationProperties.Name="Analizar unidad"
                                                Style="{StaticResource AccentButtonStyle}" />
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </controls:ItemsRepeater.ItemTemplate>
            </controls:ItemsRepeater>
        </ScrollViewer>
    </Grid>
</Page>
